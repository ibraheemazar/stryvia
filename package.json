{
  "name": "stryvia",
  "version": "0.0.0",
  "private": true,
  "description": "STRYVIA - Software platform for valuing brand integration opportunities in TV and film",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/config/*",
    "services/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:db": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "dev:engine": "cd services/engine && . .venv/bin/activate && uvicorn stryvia_engine.main:app --reload --port 8000",
    "dev:producer": "npm run dev --workspace=@stryvia/producer",
    "dev:admin": "npm run dev --workspace=@stryvia/admin",
    "dev:all": "concurrently --names engine,producer,admin --prefix-colors cyan,magenta,yellow \"npm run dev:engine\" \"npm run dev:producer\" \"npm run dev:admin\"",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.17.0",
    "@stryvia/eslint-config": "*",
    "@stryvia/prettier-config": "*",
    "@stryvia/typescript-config": "*",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.20.0"
  },
  "prettier": "@stryvia/prettier-config",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}
