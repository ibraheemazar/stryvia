{
  "name": "@stryvia/types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript types — single source of truth for all data flowing through STRYVIA.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --build",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@stryvia/typescript-config": "*",
    "typescript": "5.9.3"
  }
}
