# STRYVIA valuation engine — local environment template.
#
# Copy to `.env` (gitignored) and fill in real values. The engine reads this
# file at startup via pydantic-settings; CI / production should inject the
# same variables through the platform's secret manager rather than this file.

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
# One of: development | test | production
ENVIRONMENT=development

# Standard Python log level (DEBUG, INFO, WARNING, ERROR, CRITICAL).
LOG_LEVEL=INFO

# Log output format. "console" is human-readable for local dev; "json" emits
# one structured record per line, suitable for log aggregators.
LOG_FORMAT=console

# Bind address for `uvicorn`. 127.0.0.1 by default for safety; switch to 0.0.0.0
# inside containers.
HOST=127.0.0.1
PORT=8000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Async psycopg 3 URL. The engine connects as the least-privilege `stryvia_app`
# runtime role (read/write on the six domain schemas), NOT as the `stryvia`
# superuser defined in infrastructure/docker/.env. The local-dev password for
# `stryvia_app` is set in infrastructure/docker/initdb/03-roles.sql.
DATABASE_URL=postgresql+psycopg://stryvia_app:stryvia_app_devpw@localhost:5432/stryvia_dev

# Echo SQL statements to the log. Off by default — useful for debugging.
DB_ECHO=false

# Connection pool sizing.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ---------------------------------------------------------------------------
# AI providers
# ---------------------------------------------------------------------------
# Anthropic API key — used by stryvia_engine.core.anthropic_client, the single
# point through which all Claude API calls are made.
#
#   Where to get one: https://console.anthropic.com/ → API Keys
#   Format: sk-ant-…
#
# NOT required in Phase 1A (no AI calls are wired up yet). REQUIRED starting
# Phase 1B; the engine will refuse to start in production without it.
# Treat this value like a password: never commit it, never log it, never
# paste it into chat or PRs.
ANTHROPIC_API_KEY=sk-ant-replace-with-your-key
